# ──────────────────────────────────────────────
#  Medical Image Dataset Monitor — Environment
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is for LOCAL development only.
# For GitHub Actions, add these as Repository Secrets instead.

# Kaggle API Credentials
# Get from: https://www.kaggle.com/settings → "API" section → "Create New Token"
# This downloads a kaggle.json with your username and key.
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Slack Incoming Webhook URL
# Get from: https://api.slack.com/messaging/webhooks
# 1. Create a Slack App → Enable "Incoming Webhooks"
# 2. Add a webhook to your target channel
# 3. Copy the webhook URL here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
